---
interface Props {
  title: string;
  description?: string;
  href: string;
  pubDate?: Date;
  tags?: string[];
  readingTime?: string;
}

const { title, description, href, pubDate, tags = [], readingTime } = Astro.props;

const formattedDate = pubDate
  ? new Intl.DateTimeFormat('en-SG', { year: 'numeric', month: 'long', day: 'numeric' }).format(pubDate)
  : null;
---

<article class="group border-t border-parchment-200 py-8">
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-4 mb-3">
        {formattedDate && <p class="label">{formattedDate}</p>}
        {readingTime && <p class="label">{readingTime}</p>}
      </div>
      <h3 class="display text-2xl md:text-3xl text-ink-900 mb-3 group-hover:text-forest-900 transition-colors duration-200">
        <a href={href} class="focus:outline-none">{title}</a>
      </h3>
      {description && (
        <p class="text-ink-500 font-light leading-relaxed max-w-prose">{description}</p>
      )}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <span class="text-xs font-body font-medium tracking-wide px-3 py-1 bg-parchment-100 text-ink-500 rounded-full border border-parchment-200">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
    <a
      href={href}
      class="shrink-0 mt-1 label hover:text-forest-900 transition-colors duration-200 whitespace-nowrap"
      aria-label={`Read ${title}`}
    >
      Read →
    </a>
  </div>
</article>
