---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  year?: string;
}

const { title, description, tags = [], href, year } = Astro.props;
---

<article class="group border-t border-parchment-200 py-8 transition-colors duration-200">
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
    <div class="flex-1">
      {year && <p class="label mb-3">{year}</p>}
      <h3 class="display text-2xl md:text-3xl text-ink-900 mb-3 group-hover:text-forest-900 transition-colors duration-200">
        {href ? <a href={href} class="focus:outline-none focus:text-forest-900">{title}</a> : title}
      </h3>
      <p class="text-ink-500 font-light leading-relaxed max-w-prose">{description}</p>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <span class="text-xs font-body font-medium tracking-wide px-3 py-1 bg-parchment-100 text-ink-500 rounded-full border border-parchment-200">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
    {href && (
      <a
        href={href}
        target={href.startsWith('http') ? '_blank' : undefined}
        rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
        class="shrink-0 mt-1 label hover:text-forest-900 transition-colors duration-200 whitespace-nowrap"
        aria-label={`View ${title}`}
      >
        View ↗
      </a>
    )}
  </div>
</article>
